{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🧠 Evolution Context Engine (ACE) - Auto Start",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/EVO_IA/ace-client/ace_server.py",
                "${workspaceFolder}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true,
                "group": "evolution-ace"
            },
            "runOptions": {
                "runOn": "default"
            }
        }
    ]
}