generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  config    Json     @default("{}")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  templates ProductTemplate[]
  quotes    Quote[]
  logs      AuditLog[]
  clients        Client[]
  quoteTemplates Template[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String   @unique
  role         String   @default("user")
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model ProductTemplate {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  fields       Json     @default("[]")
  formulaLogic String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@map("product_templates")
}

model Quote {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  clientId   String   @map("client_id")
  templateId String?  @map("template_id")
  
  quoteNumber String  @map("quote_number")
  title      String
  status     String   @default("draft")
  notes      String?
  currency   String   @default("BRL")

  subtotal   Float    @default(0)
  tax        Float    @default(0)
  total      Float    @default(0)

  createdAt  DateTime @default(now()) @map("created_at")

  items      QuoteItem[]

  tenant     Tenant @relation(fields: [tenantId], references: [id])

  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(uuid())
  quoteId     String  @map("quote_id")

  name        String
  description String?

  price       Float
  quantity    Int
  total       Float

  quote       Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  timestamp  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@map("audit_logs")
}

model Client {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("clients")
}

model Template {
  id          String         @id @default(uuid())
  tenantId    String         @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime       @default(now()) @map("created_at")
  items       TemplateItem[]
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  @@map("quote_templates")
}

model TemplateItem {
  id              String   @id @default(uuid())
  templateId      String   @map("template_id")
  name            String
  description     String?
  price           Float
  quantityDefault Int      @default(1) @map("quantity_default")
  template        Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("quote_template_items")
}
