{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ActionPacket",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "packet_version": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+$"
        },
        "intent_id": {
            "type": "string"
        },
        "state": {
            "type": "string",
            "enum": [
                "DRAFT",
                "PREFLIGHT",
                "APPROVED",
                "EXECUTING",
                "PROOF_READY",
                "VERIFIED"
            ]
        },
        "requested_ops": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "string",
                "enum": [
                    "READ_FILE",
                    "WRITE_FILE_SCOPED",
                    "RUN_TESTS",
                    "BUILD_LOCAL",
                    "DIFF_ONLY"
                ]
            }
        },
        "file_scope": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "string"
            }
        },
        "commands": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "string"
            }
        },
        "network": {
            "type": "boolean"
        },
        "risk_level": {
            "type": "string",
            "enum": [
                "LOW",
                "MEDIUM",
                "HIGH"
            ]
        },
        "human_ack_required": {
            "type": "boolean"
        },
        "expected_artifacts": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "string"
            }
        },
        "rollback_plan": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "packet_version",
        "intent_id",
        "state",
        "requested_ops",
        "file_scope",
        "commands",
        "network",
        "risk_level",
        "human_ack_required"
    ]
}